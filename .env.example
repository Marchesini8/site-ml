PORT=3000

# PostgreSQL online no Railway
DATABASE_URL=postgresql://postgres:SUA_SENHA@SEU_HOST_RAILWAY:5432/railway
PGSSL_DISABLE=false
PG_POOL_MAX=10

# Envio de e-mail para codigo de verificacao
EMAIL_FROM=Site ML <no-reply@seudominio.com>
EMAIL_APP_NAME=Site ML
EMAIL_SMTP_HOST=smtp.seuprovedor.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=seu-usuario-smtp
EMAIL_SMTP_PASS=sua-senha-smtp
EMAIL_VERIFICATION_EXP_MINUTES=10

# Google Login opcional
GOOGLE_CLIENT_ID=

# Pagamentos
PAYMENT_API_URL=https://api.ironpayapp.com.br/api/public/v1
PAYMENT_API_KEY=
PAYMENT_PIX_ENDPOINT=/transactions
IRONPAY_OFFER_HASH=
IRONPAY_PRODUCT_HASH=
IRONPAY_POSTBACK_URL=https://seu-app.up.railway.app/ironpay
IRONPAY_EXPIRE_IN_DAYS=1
DEFAULT_PHONE_NUMBER=21999999999
DEFAULT_STATE=RJ
DEFAULT_NEIGHBORHOOD=Centro
ALLOW_MOCK_PIX=false
IRONPAY_WEBHOOK_SECRET=
